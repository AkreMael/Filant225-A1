rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to validate 4-digit PIN
    function isValidPin(data) {
      return !('pin' in data) || data.pin == null || (data.pin is string && data.pin.size() == 4 && data.pin.matches('^[0-9]{4}$'));
    }

    match /Connexions/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidPin(request.resource.data);
    }

    match /Clients/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidPin(request.resource.data);
    }

    match /travailleurs/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidPin(request.resource.data);
    }

    match /agences/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidPin(request.resource.data);
    }

    match /proprietaires/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidPin(request.resource.data);
    }

    match /entreprises/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidPin(request.resource.data);
    }

    match /Disponible/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
