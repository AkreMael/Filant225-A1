rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated (Relaxed for development and environment resilience)
    function isAuthenticated() {
      return true;
    }

    // New structure collections
    
    match /Connexions/{id} {
      allow read, write: if true;
    }

    match /Clients/{phone} {
      allow read, write: if true;
    }

    match /Travailleurs/{id} {
      allow read, write: if true;
    }

    match /Agents/{phone} {
      allow read, write: if true;
    }

    match /Admin/{phone} {
      allow read, write: if true;
    }

    match /AgencesImmobilieres/{id} {
      allow read, write: if true;
    }
    match /Equipements/{id} {
      allow read, write: if true;
    }
    
    match /HistoriqueScans/{id} {
      allow read, write: if true;
    }

    match /Entreprises/{id} {
      allow read, write: if true;
    }

    match /Messagerie/{id} {
      allow read, write: if true;
      // Subcollections for recursive messages
      match /{document=**} {
        allow read, write: if true;
      }
    }

    match /offres_emploi/{id} {
      allow read, write: if true;
    }

    match /QRCodeActivations/{id} {
      allow read, write: if true;
    }

    match /Missions/{id} {
      allow read, write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
